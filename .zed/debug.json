// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "adapter": "CodeLLDB",
    "label": "Test (package: filereduce)",
    "build": {
      "label": "Test (package: $ZED_CUSTOM_RUST_PACKAGE)",
      "command": "cargo",
      "args": ["run", "--bin", "api"],
      "label": "Run (binary: api)",
      "args": ["test", "-p", "$ZED_CUSTOM_RUST_PACKAGE", "--no-run"],
      "env": {},
      "cwd": "$ZED_CUSTOM_RUST_MANIFEST_DIRNAME",
      "use_new_terminal": false,
      "allow_concurrent_runs": false,
      "reveal": "always",
      "reveal_target": "dock",
      "hide": "never",
      "tags": [],
      "shell": "system",
      "show_summary": false,
      "show_command": false,
      "save": "none",
      "hooks": [],
    },
    "sourceLanguages": ["rust"],
  },
]
